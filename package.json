import { useNavigate } from 'react-router-dom'

function SavedPage({ saved, dispatch }) {
  const navigate = useNavigate()

  if (saved.length === 0) {
    return (
      <div className="page">
        <h2>Saved Items</h2>
        <p className="empty-state">
          You haven't saved anything yet. Search for a food and save it from the detail page.
        </p>
      </div>
    )
  }

  return (
    <div className="page">
      <h2>Saved Items ({saved.length})</h2>
      <div className="saved-list">
        {saved.map((product) => {
          const energy = product.nutriments?.['energy-kcal_100g'] ?? null
          const protein = product.nutriments?.['proteins_100g'] ?? null

          return (
            <div key={product.code} className="saved-item">
              {product.image_small_url && (
                <img
                  src={product.image_small_url}
                  alt={product.product_name}
                  className="saved-item-img"
                />
              )}
              <div className="saved-item-info">
                <h3>{product.product_name}</h3>
                {product.brands && <p className="saved-item-brand">{product.brands}</p>}
                <div className="saved-item-stats">
                  {energy !== null && <span>{Math.round(energy)} kcal</span>}
                  {protein !== null && <span>{protein}g protein</span>}
                </div>
              </div>
              <div className="saved-item-actions">
                <button
                  className="btn-view"
                  onClick={() => navigate(`/product/${product.code}`)}
                >
                  View Details
                </button>
                <button
                  className="btn-remove"
                  onClick={() => dispatch({ type: 'REMOVE', code: product.code })}
                >
                  Remove
                </button>
              </div>
            </div>
          )
        })}
      </div>
    </div>
  )
}

export default SavedPage
